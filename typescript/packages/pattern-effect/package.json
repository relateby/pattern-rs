{
  "name": "@relateby/pattern-effect",
  "version": "0.1.0",
  "description": "Effect interop utilities for @relateby/pattern",
  "license": "BSD-3-Clause",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/relateby/pattern-rs.git"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build:ts": "tsc",
    "build": "npm run build:ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "pack:release": "npm pack --pack-destination ../../../target/npm-packages"
  },
  "peerDependencies": {
    "@relateby/pattern": ">=0.4.2",
    "effect": ">=3.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.0",
    "typescript": "^5.0.0",
    "vitest": "^2.0.0"
  },
  "overrides": {
    "why-is-node-running": "3.2.2"
  }
}
